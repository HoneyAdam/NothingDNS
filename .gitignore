# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Coverage output directory (defense-in-depth: cover/ may contain
# non-.out files; the *.out pattern above covers the files inside)
/cover/

# Go workspace file
go.work

# Dependency directories (remove the comment below to include it)
# vendor/

# Build directories
/bin/
/dist/
/build/
/web/dist/
/web/dist-ssr/
/web/node_modules/

# Binary output from go build
/nothingdns
/dnsctl
/cmd/nothingdns/nothingdns
/cmd/dnsctl/dnsctl

# IDE specific files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Environment files
.env
.env.local
.env.*.local

# Log files
*.log
/logs/

# Test artifacts
/coverage/
/test-results/
coverage.html
coverage.out
*.prof
*.coverprofile

# Release binaries (built by goreleaser / make release)
/release/

# Configuration files (keep examples)
/nothingdns.yaml
/dnsctl.yaml
*.conf

# Database files
*.db

# Zone/runtime data (test fixtures can be tracked with force-add when needed)
*.zone
/zones/
/zones-db/

# AI assistant config (personal)
.claude/

# Test run configs (local)
configs/test-run.yaml
local-test.yaml

# Temporary files
/tmp/
/temp/
*.tmp
*.bak
*.orig
*.rej

# Debug files
debug
__debug_bin

# Security scan artifacts
security-report/*
!security-report/
!security-report/SECURITY-REPORT.md

# Playwright MCP artifacts
.playwright-mcp/

# Runtime cache files
cache.json

# Cluster state directories (created at runtime by the cluster subsystem)
clusters/

# IXFR journal files
ixfr-journals/

# Web coverage output
web/coverage.out

# Binary backups
*.exe~

# OS specific files
Thumbs.db
.DS_Store
*.icloud

# Accidental package-manager lockfiles outside the tracked npm lockfile.
/pnpm-lock.yaml
/package-lock.json
/yarn.lock
/web/pnpm-lock.yaml
/web/yarn.lock

.dfmt/
.wrongstack/

# Local temp files (per CLAUDE.md / repo convention)
.temp_files/

# Frontend coverage output directory
web/coverage/
