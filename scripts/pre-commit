#!/bin/bash
# NothingDNS Pre-commit Hook
# Installs automatically when .git/hooks symlinks to this file
# Or run: ./scripts/install-hooks.sh

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running NothingDNS pre-commit checks...${NC}"

# Get Go files that were modified
GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' | grep -v '_test\.go' | grep -v 'vendor/' || true)

if [ -z "$GO_FILES" ]; then
    echo -e "${GREEN}No Go files to check${NC}"
    exit 0
fi

# 1. Run go vet
echo -e "${YELLOW}Running go vet...${NC}"
if ! go vet ./...; then
    echo -e "${RED}✗ go vet failed${NC}"
    exit 1
fi
echo -e "${GREEN}✓ go vet passed${NC}"

# 2. Check formatting
echo -e "${YELLOW}Checking formatting...${NC}"
UNFORMATTED=$(gofmt -l $GO_FILES)
if [ -n "$UNFORMATTED" ]; then
    echo -e "${RED}✗ Files not formatted:${NC}"
    echo "$UNFORMATTED"
    echo -e "${YELLOW}Run: gofmt -w ${UNFORMATTED}${NC}"
    exit 1
fi
echo -e "${GREEN}✓ Formatting OK${NC}"

# 3. Run short tests for modified packages
echo -e "${YELLOW}Running tests...${NC}"
MODIFIED_PACKAGES=$(git diff --cached --name-only --diff-filter=ACM | xargs -I{} dirname {} | sort -u | grep -v '^\.$' | grep -v vendor || true)

if [ -n "$MODIFIED_PACKAGES" ]; then
    for pkg in $MODIFIED_PACKAGES; do
        if [ -d "$pkg" ] && ls "$pkg"/*_test.go 1> /dev/null 2>&1; then
            echo -e "  Testing $pkg..."
            if ! go test -short -count=1 "$pkg"; then
                echo -e "${RED}✗ Tests failed in $pkg${NC}"
                exit 1
            fi
        fi
    done
fi
echo -e "${GREEN}✓ Tests passed${NC}"

# 4. Check for debug prints (common mistakes)
echo -e "${YELLOW}Checking for debug prints...${NC}"
DEBUG_PATTERNS="fmt\.Println.*DEBUG\|log\.Println.*DEBUG\|console\.Log\|process\.exit"
if grep -rnE "$DEBUG_PATTERNS" $GO_FILES 2>/dev/null; then
    echo -e "${RED}✗ Debug prints found in staged files${NC}"
    exit 1
fi
echo -e "${GREEN}✓ No debug prints${NC}"

# 5. Check for TODO without issue numbers
echo -e "${YELLOW}Checking for TODOs...${NC}"
TODOS=$(grep -rnE "TODO[:\(]" $GO_FILES | grep -vE "TODO\([A-Z]+-[0-9]+\)" || true)
if [ -n "$TODOS" ]; then
    echo -e "${YELLOW}⚠ TODOs found without issue references:${NC}"
    echo "$TODOS"
fi

# 6. Build to catch compilation errors
echo -e "${YELLOW}Building...${NC}"
if ! go build -o /dev/null ./cmd/nothingdns; then
    echo -e "${RED}✗ Build failed${NC}"
    exit 1
fi
echo -e "${GREEN}✓ Build passed${NC}"

echo -e "${GREEN}✓ All pre-commit checks passed!${NC}"
exit 0